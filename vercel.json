{
  "framework": "nextjs",
  "buildCommand": "NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard next build",
  "installCommand": "npm ci",
  "devCommand": "npm run dev",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "staging": true,
      "dev": true
    }
  },
  "github": {
    "silent": false,
    "autoAlias": true
  },
  "crons": [
    { "path": "/api/cron/sync", "schedule": "0 */2 * * *" },
    { "path": "/api/cron/forense", "schedule": "0 6 * * *" },
    { "path": "/api/cron/won-track", "schedule": "0 7 * * 1" },
    { "path": "/api/cron/digest", "schedule": "0 12 * * *" }
  ]
}
